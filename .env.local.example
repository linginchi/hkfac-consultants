# ============================================
# FAC Hong Kong - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================

# ============================================
# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============================================
# Resend Configuration (Email Service)
# Get your API key from: https://resend.com/api-keys
# ============================================
RESEND_API_KEY=re_your_resend_api_key

# ============================================
# Admin Authentication Settings
# ============================================
# Admin email (default: mark@hkfac.com) - Hardcoded in app for security
# Only this email can access the admin dashboard

# Session secret for JWT signing (generate a strong random string)
# You can generate one with: openssl rand -base64 32
ADMIN_SESSION_SECRET=your-very-secure-random-session-secret-min-32-chars

# Initial admin password (only used for first-time setup via SQL)
# IMPORTANT: Change this immediately after first login!
# The system will force password change on first login.

# ============================================
# Database Setup Instructions
# ============================================

# 1. Run supabase-setup.sql to create the leads table for contact form
# 2. Run supabase-team-setup.sql to create team members table
# 3. Run supabase-admin-setup.sql to create admin authentication tables

# ============================================
# Table Schemas Reference
# ============================================

# --- leads table (Contact Form) ---
# - id: uuid (primary key)
# - first_name, last_name, email, company, title
# - region, investment_focus, message
# - whitepaper_request: boolean
# - created_at, email_sent, email_sent_at

# --- team_members table ---
# - id, first_name, last_name, email
# - role_en, role_zh_hk, role_zh_cn
# - bio_en, bio_zh_hk, bio_zh_cn (max 200 chars)
# - value_prop_en, value_prop_zh_hk, value_prop_zh_cn (max 150 chars)
# - illustration_url, illustration_status
# - member_type, display_order, is_active
# - expertise_areas[], certifications[], awards[]
# - years_experience, client_regions[]

# --- admin_users table ---
# - id, email, password_hash
# - is_first_login: boolean (default true)
# - is_active, role
# - created_at, updated_at, last_login_at
# - failed_login_attempts, locked_until

# --- admin_sessions table ---
# - id, user_id, token
# - ip_address, user_agent
# - expires_at, created_at, last_active_at

# --- verification_codes table ---
# - id, email, code
# - used, used_at, expires_at, created_at

# --- admin_activity_log table ---
# - id, user_id, action, details (JSONB)
# - ip_address, user_agent, created_at
